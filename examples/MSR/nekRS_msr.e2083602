<<< void UDF_Setup(nrs_t *nrs)
<<< {
<<<   mesh_t *mesh = nrs->meshV;
<<<   cds_t *cds = nrs->cds;
<<< 
<<<   o_qt = platform->device.malloc(nrs->fieldOffset * sizeof(dfloat));
<<<   fillQT(mesh->Nelements,mesh->o_y,mesh->o_x,o_qt);  
<<< 
<<<   udf.properties = &uservp;
<<<   udf.sEqnSource = &userq;
<<<   
<<<   double *wd = (double *) nek::scPtr(1);
<<<   platform_t* platform = platform_t::getInstance();
<<<   nrs->o_usrwrk = platform->device.malloc(2*nrs->fieldOffset,sizeof(dfloat));
<<<   nrs->o_usrwrk.copyFrom(wd,mesh->Nlocal*sizeof(dfloat),1*nrs->fieldOffset*sizeof(dfloat));
<<< 
<<<   const int scalarFieldStart = 1;
<<<   platform->options.getArgs("VISCOSITY", mueLam); 
<<<   platform->options.getArgs("DENSITY", rho); 
<<<   RANSktau::setup(nrs, mueLam, rho, scalarFieldStart);
<<<   
<<< 
<<< }
<<< 
<<< 

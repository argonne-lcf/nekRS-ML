<<<   if (platform->comm.mpiRank == 0) {
<<<     printf("q_tot = %d %.16e %.16e\n",tstep,time,q_tot);
<<<   }
<<< */
<<< 
<<<   clipT(mesh->Nelements, 0.0, nrs->cds->o_S);
